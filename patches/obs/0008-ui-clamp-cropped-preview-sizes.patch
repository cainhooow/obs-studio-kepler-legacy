# Patch-Name: 0008-ui-clamp-cropped-preview-sizes.patch
# Patch-Origin: Upstream OBS Studio backport for cropped preview size clamping.
# Patch-Reason: Prevent negative preview geometry when an item is cropped more heavily than its source dimensions.
# Patch-Risk: Low. UI-only bounds clamp.

diff --git a/UI/window-basic-preview.cpp b/UI/window-basic-preview.cpp
--- a/UI/window-basic-preview.cpp
+++ b/UI/window-basic-preview.cpp
@@ -450,11 +450,10 @@ static vec2 GetItemSize(obs_sceneitem_t *item)
 
 		obs_sceneitem_get_scale(item, &scale);
 		obs_sceneitem_get_crop(item, &crop);
-		size.x = float(obs_source_get_width(source) - crop.left -
-			       crop.right) *
-			 scale.x;
-		size.y = float(obs_source_get_height(source) - crop.top -
-			       crop.bottom) *
-			 scale.y;
+		size.x = fmaxf(float((int)obs_source_get_width(source) -
+				     crop.left - crop.right), 0.0f);
+		size.y = fmaxf(float((int)obs_source_get_height(source) -
+				     crop.top - crop.bottom), 0.0f);
+		vec2_mul(&size, &size, &scale);
 	}
 
 	return size;
